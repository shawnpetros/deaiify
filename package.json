{
  "name": "deaiify",
  "version": "3.0.0",
  "description": "Ban LLM em-dashes and en-dashes before delivery, rewrite via embedded LLM",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "openclaw.json",
    "README.md",
    "package.json"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "prebuild": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@openclaw/plugin-sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "openclaw": {
    "plugin": true,
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "builtWith": "2026.4.11",
      "sdk": "2026.4.11",
      "minGateway": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.11",
      "sdkVersion": "2026.4.11"
    },
    "extensions": [
      "./dist/index.js"
    ]
  }
}
